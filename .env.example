# Copy to .env and fill with values from your standalone Supabase project dashboard.
# Do NOT commit .env — it is gitignored in this repo.

SUPABASE_PROJECT_ID="your-project-ref"
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-anon-key"

VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"

# Used only by migration scripts (scripts/migrate-from-lovable.mjs) — never commit real values.
# OLD_SUPABASE_URL="https://zjldhczhlyxzvswbxeuq.supabase.co"
# OLD_SUPABASE_SERVICE_ROLE_KEY="..."
# NEW_SUPABASE_URL="https://your-project-ref.supabase.co"
