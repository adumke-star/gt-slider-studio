# Copy to .env and fill with values from your standalone Supabase project dashboard.
# Do NOT commit .env — it is gitignored in this repo.
#
# Fastest path: bash scripts/fresh-start.sh (after npx supabase login + SUPABASE_PROJECT_REF)

SUPABASE_PROJECT_ID="your-project-ref"
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-anon-key"

VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
